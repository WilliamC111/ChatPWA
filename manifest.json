{
  "id": "/?source=pwa",
  "name": "Chat para Héroes",
  "short_name": "PWA Chat",
  "description": "Una PWA de chat de ejemplo que demuestra el uso completo del manifest para una rica experiencia de instalación e integración con el sistema operativo.",
  "lang": "es-MX",
  "dir": "ltr",
  "categories": ["social", "chat", "education"],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8cefd5e1b",

  "start_url": "index.html?utm_source=pwa",
  "scope": "./",
  "scope_extensions": [
    { "origin": "*.example.com" },
    { "origin": "specific.example.com" }
  ],

  "theme_color": "#3498db",
  "background_color": "#3498db",

  "display": "standalone",
  "display_override": ["window-controls-overlay", "minimal-ui", "standalone"],
  "orientation": "any",

  "launch_handler": {
    "client_mode": ["focus-existing", "navigate-new"]
  },

  "icons": [
    {
      "src": "img/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "img/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "img/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "img/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "img/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "img/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "img/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "img/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],

  "screenshots": [
    {
      "src": "img/screenshot-mobile.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Vista principal del chat en un dispositivo móvil"
    },
    {
      "src": "img/screenshot-desktop.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Vista principal del chat en un escritorio"
    }
  ],

  "shortcuts": [
    {
      "name": "Crear nuevo mensaje",
      "short_name": "Nuevo",
      "description": "Inicia la composición de un nuevo mensaje.",
      "url": "index.html?action=new-message",
      "icons": [{ "src": "img/icons/icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Ver mis contactos",
      "short_name": "Contactos",
      "description": "Abre la lista de contactos disponibles.",
      "url": "index.html?action=contacts",
      "icons": [{ "src": "img/icons/icon-96x96.png", "sizes": "96x96" }]
    }
  ],

  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.app1",
      "id": "com.example.app1"
    },
    {
      "platform": "itunes",
      "url": "https://itunes.apple.com/app/example-app1/id123456789"
    }
  ],
  "prefer_related_applications": false,

  "share_target": {
    "action": "index.html?action=share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/jpeg", "image/png", "image/gif", "video/mp4"]
        }
      ]
    }
  },

  "protocol_handlers": [
    {
      "protocol": "web+chathero",
      "url": "index.html?action=protocol&target=%s"
    }
  ],

  "file_handlers": [
    {
      "action": "index.html?action=open-file",
      "accept": {
        "text/plain": [".txt", ".md"],
        "image/jpeg": [".jpg", ".jpeg"],
        "application/json": ".json"
      },
      "icons": [
        {
          "src": "img/icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],

  "note_taking": {
    "new_note_url": "/index.html?action=new-note",
    "capture_links": true
  },

  "edge_side_panel": {
    "preferred_width": 480
  }
}